        "        print(f\"ELITE: Vendedor {nome} superou a meta com R${vendas_vendedor:.2f} em vendas.\")\n",
        "    else:\n",
        "        print(f\"INFO: Vendedor {nome} - Vendas: R${vendas_vendedor:.2f} (não atingiu a meta ou é válido).\")\n",
        "\n",
        "print(\"\\n--- Média de Vendas dos Vendedores de Elite Válidos ---\")\n",
        "if contador_elite > 0:\n",
        "    media_vendas_elite = vendas_total_elite / contador_elite\n",
        "    print(f\"Média de vendas dos vendedores de elite válidos: R${media_vendas_elite:.2f}\")\n",
        "else:\n",
        "    print(\"Nenhum vendedor de elite válido encontrado.\")\n",
        "\n",
        "print(\"--- Fim do Relatório ---\")"
